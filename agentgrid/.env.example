# Database (Turso / libsql)
# Get these from: turso db show agentgrid && turso db tokens create agentgrid
DATABASE_URL=libsql://your-db-name-username.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token

# NextAuth
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=https://your-vercel-deployment-url.vercel.app

# Google OAuth (optional — remove Google provider in auth.ts if not using)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
