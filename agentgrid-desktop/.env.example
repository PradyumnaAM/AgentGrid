# AgentGrid account service used by the desktop OAuth flow.
AGENTGRID_ACCOUNT_URL=http://127.0.0.1:3000

# Packaged builds should point at the production account service.
AGENTGRID_PACKAGED_ACCOUNT_URL=https://example.com

# Vite renderer URL used by Electron in development.
AGENTGRID_RENDERER_DEV_URL=http://localhost:5173

# Optional Windows terminal backend fallback. Set to 1 to disable ConPTY.
AGENTGRID_DISABLE_CONPTY=0
